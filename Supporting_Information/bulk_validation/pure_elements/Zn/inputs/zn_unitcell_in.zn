log log.zn.lammps

units           metal
atom_style      atomic
boundary        p p p

read_data       zn_unitcell.data

pair_style      meam/c
pair_coeff      * * library.meam Zn Mg ZnMg.meam Mg

neighbor        2.0 bin
neigh_modify    delay 10 check yes

thermo          50
thermo_style    custom step pe etotal lx ly lz press pxx pyy pzz vol

fix             1 all box/relax aniso 0.0 vmax 0.001
min_style       cg
minimize        1e-12 1e-12 20000 20000
unfix           1

write_data      zn_unitcell_relaxed.data


