units           metal
atom_style      atomic
boundary        p p p

read_data       mg2zn11.data     


pair_style      meam/c
pair_coeff      * * library.meam Zn Mg ZnMg.meam Mg Zn


neighbor        2.0 bin
neigh_modify    delay 0 every 1 check yes


# Hexagonal MgZn2 (C14) → allow anisotropic stress relaxation
fix             relax all box/relax aniso 0.0 vmax 0.001

min_style       cg
min_modify      line quadratic dmax 0.1

# Very tight tolerances for phonon-quality relaxation
minimize        1e-12 1e-12 20000 20000


thermo          50
thermo_style    custom step pe etotal pxx pyy pzz vol lx ly lz

write_data      mg2zn11_relaxed.data
write_restart   mg2zn11_relaxed.restart
