# Complete workflow: re-relax then compute elastic constants

units           metal
atom_style      atomic
boundary        p p p

read_data       mgzn2_relaxed.data

pair_style      meam/c
pair_coeff      * * library.meam Zn Mg ZnMg.meam Mg Zn

# Full relaxation with this potential
fix             1 all box/relax aniso 0.0 vmax 0.001
minimize        1.0e-15 1.0e-15 100000 1000000
unfix           1

write_data      mgzn2_rerelaxed.data

# Check stress is near zero
run             0
variable        p0 equal press
print "Pressure after relaxation: ${p0} bar"

variable        pxx0 equal pxx

change_box      all x scale 1.005 remap
run             0
variable        pxx1 equal pxx
print "Pxx after +0.5% strain: ${pxx1} bar"
print "Change: $(v_pxx1-v_pxx0) bar"

variable        C11_test equal -(v_pxx1-v_pxx0)/0.005*0.0001
print "C11 estimate = ${C11_test} GPa"
