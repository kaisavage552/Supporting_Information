#!/bin/bash
#PBS -N zn_phonons
#PBS -q v1_small72
#PBS -l select=1:ncpus=1:mem=2gb
#PBS -l walltime=01:00:00
#PBS -j oe
#PBS -V

cd "$PBS_O_WORKDIR" || exit 1

module load LAMMPS/2Aug2023_update2-foss-2023a-kokkos

LAMMPS_CMD=lmp

echo "Running single supercell calculation ..."

$LAMMPS_CMD -in zn_phonons_in.force

mv forces.dump forces-001.dump

