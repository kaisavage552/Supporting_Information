units           metal
atom_style      atomic
boundary        p p p

read_data       ${STRUCT}

pair_style      meam/c
pair_coeff      * * library.meam Zn Mg ZnMg.meam Mg Zn

thermo          10
thermo_style    custom step pe fmax fnorm

fix             1 all box/relax aniso 0.0 vmax 0.001

min_style       cg
minimize        1e-12 1e-12 100000 1000000

write_data      ${STRUCT}_relaxed.data
