# Surface energy relaxation: Mg_1012_15L
units metal
atom_style atomic
boundary p p p

read_data ../Mg_1012_15L.data

pair_style meam
pair_coeff * * ../library.meam Zn Mg ZnMg.meam Mg

thermo 10
thermo_style custom step pe lx ly lz press pxx pyy pzz

min_style cg
minimize 1e-10 1e-10 10000 100000

variable pe equal pe
print "FINAL_PE = ${pe}"
print "FINAL_LX = $(lx)"
print "FINAL_LY = $(ly)"
print "FINAL_LZ = $(lz)"
